# Copy this file to .env.local and fill in values as needed.
# Never commit .env.local or any file with real secrets.
# Variables that must be readable in the browser need the NEXT_PUBLIC_ prefix.

# --- App ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (auth + database, Phase 1 — see ROADMAP.md) ----------------
# Project Settings -> API in the Supabase dashboard. The publishable key is
# safe to expose to the browser (Row Level Security enforces access, not
# this key) — never put the service-role/secret key in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Billing (wired up in Phase 3 — see ROADMAP.md) -----------------------
BILLING_PROVIDER_SECRET_KEY=
