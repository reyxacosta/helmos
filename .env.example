# Copy this file to .env.local and fill in values as needed.
# Never commit .env.local or any file with real secrets.
# Variables that must be readable in the browser need the NEXT_PUBLIC_ prefix.

# --- App ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (wired up in Phase 2 — see ROADMAP.md) --------------------
DATABASE_URL=

# --- Auth (wired up in Phase 1 — see ROADMAP.md) -------------------------
AUTH_SECRET=

# --- Email (provider TBD) ------------------------------------------------
EMAIL_FROM=

# --- Billing (wired up in Phase 3 — see ROADMAP.md) -----------------------
BILLING_PROVIDER_SECRET_KEY=
